{
    "name": "dungeon-blitz-r",
    "version": "1.0.0",
    "description": "Dungeon Blitz: R",
    "main": "index.js",
    "scripts": {
      "dev": "npm --prefix src/server run dev",
      "dev:discord-bridge": "npm --prefix src/server run dev:discord-bridge",
      "dev:with-discord": "concurrently \"npm run dev\" \"npm run dev:discord-bridge\"",
      "build": "npm --prefix src/server run build",
      "start:multiplayer": "npm --prefix src/server run start:multiplayer",
      "start:discord-bridge": "npm --prefix src/server run start:discord-bridge",
      "start:with-discord": "concurrently \"npm run start:multiplayer\" \"npm run start:discord-bridge\""
    },
    "author": "The Minesa Studios",
    "license": "MIT",
    "devDependencies": {
      "concurrently": "^9.0.1"
    }
  }